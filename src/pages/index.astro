---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Konstanty Szumigaj - Computer Vision Engineer</title>
    <meta
      name="description"
      content="Computer Vision and Software Engineer specializing in 3D vision, image processing, and algorithm optimization."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header lang="en" />

    <main class="container">
      <!-- INTRO SECTION -->
      <section class="section">
        <h1>Konstanty Szumigaj</h1>
        <h2 class="text-accent">
          Computer Vision Engineer / Software Developer
        </h2>

        <p>
          CV engineer. C++ and Python. 3D vision, image processing, performance.
        </p>

        <p class="text-mono">
          [Python] [C++] [PyTorch] [OpenCV] [CUDA]
        </p>
      </section>

      <!-- BIO SECTION -->
      <section class="section">
        <h2 class="section-title">About</h2>

        <p>
          I'm a Computer Vision Engineer with <strong>5+ years</strong> in CV and image
          processing. At <strong>Samsung Electronics</strong> I build proofs of concept —
          facial landmarks, background segmentation, Gaussian Splatting, NeRF. Things that
          are mostly still in papers.
        </p>

        <p>
          Before that, a few years at Mnemosis and Smarttech3D — algorithms for 3D/4D data,
          LiDAR systems, distributed processing. Work tends to start in Python and end up
          as optimized C++ with CUDA.
        </p>

        <p class="mb-0">
          On the side I write open-source tools — a node editor for CV pipelines, an OpenGL
          application framework, game automation bots. I like code that's fast and stays
          readable six months later.
        </p>
      </section>

      <!-- QUICK STATS -->
      <section class="section">
        <h2 class="section-title">Quick Stats</h2>

        <div class="grid">
          <div class="stat-box">
            <div class="stat-number text-accent">5+</div>
            <div class="stat-label">Years in CV/ML</div>
          </div>
          <div class="stat-box">
            <div class="stat-number text-accent">3</div>
            <div class="stat-label">Companies</div>
          </div>
          <div class="stat-box">
            <div class="stat-number text-accent">C++/Python</div>
            <div class="stat-label">Core Stack</div>
          </div>
        </div>
      </section>

      <!-- FEATURED PROJECTS -->
      <section class="section">
        <h2 class="section-title">Featured Projects</h2>

        <p>
          A few things I built.
          <a href="/projects">[View all projects →]</a>
        </p>

        <div class="featured-list">
          <div class="featured-item">
            <h3>VisionCraft - Visual Node Editor for CV</h3>
            <p>
              Node editor for building CV pipelines visually in C++20. Drag nodes, wire them up,
              watch the output update in real time.
            </p>
            <span class="text-mono text-accent"
              >[C++20, OpenCV, ImGui, GLFW, Node Editor]</span
            >
          </div>

          <div class="featured-item">
            <h3>PyShiny Hunter - Pokemon Shiny Hunter</h3>
            <p>
              Pokemon shiny hunter that actually works. Runs on an emulator, watches the screen
              with OpenCV, and soft-resets until a shiny shows up.
            </p>
            <span class="text-mono text-accent"
              >[Python, Computer Vision, Automation, OpenCV]</span
            >
          </div>
        </div>
      </section>

      <!-- CONTACT CTA -->
      <section class="section">
        <h2 class="section-title">Get in Touch</h2>

        <p>
          Working on something in CV? Have a project idea or just want to talk shop?
        </p>

        <p class="mb-0">
          <a href="/contact"><strong>[Contact me →]</strong></a>
        </p>
      </section>
    </main>

    <Footer lang="en" />
  </body>
</html>

<style>
  .stat-box {
    border: 1px solid var(--border);
    padding: 24px;
    text-align: center;
  }

  .stat-number {
    font-size: 48px;
    font-weight: bold;
    font-family: monospace;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 14px;
    text-transform: uppercase;
  }

  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 24px;
  }

  .featured-item {
    border-left: 2px solid var(--accent);
    padding-left: 16px;
  }

  .featured-item h3 {
    margin-bottom: 8px;
  }

  .featured-item p {
    margin-bottom: 8px;
  }

  /* Mobile responsive improvements */
  @media (max-width: 768px) {
    .stat-box {
      padding: 16px;
    }

    .stat-number {
      font-size: 36px;
    }

    .stat-label {
      font-size: 12px;
    }

    .featured-list {
      gap: 16px;
      margin-top: 16px;
    }

    .featured-item {
      padding-left: 12px;
    }
  }

  @media (max-width: 480px) {
    .stat-box {
      padding: 12px;
    }

    .stat-number {
      font-size: 28px;
    }

    .stat-label {
      font-size: 11px;
    }

    .featured-list {
      gap: 12px;
    }

    .featured-item {
      padding-left: 8px;
      border-left-width: 1px;
    }
  }
</style>
