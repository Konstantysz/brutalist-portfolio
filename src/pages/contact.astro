---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact - Konstanty Szumigaj</title>
    <meta
      name="description"
      content="Get in touch for computer vision and ML consulting"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header lang="en" />

    <main class="container">
      <section class="section">
        <h1>Contact</h1>
        <p>
          Working on something in CV? Have an open-source project that needs a hand,
          or just want to talk about NeRF, Gaussian Splatting, or whatever's interesting
          right now? Drop me a line.
        </p>
      </section>

      <section class="section">
        <h2 class="section-title">Get in Touch</h2>

        <div class="contact-info">
          <div class="contact-item">
            <span class="label">Email:</span>
            <a 
              href="#" 
              id="email-link" 
              data-u="amFnaW11enNrZXRzb2s=" 
              data-d="bW9jLmxpYW1nQA=="
              style="cursor: pointer; position: relative;"
              title="Click to reveal email"
            >
              <span id="email-text" style="user-select: none;">
                [Click to reveal email]
              </span>
            </a>
          </div>
          <script>
            // Multi-layer anti-bot email protection
            (function() {
              const emailLink = document.getElementById('email-link');
              const emailText = document.getElementById('email-text');
              let revealed = false;
              
              emailLink.addEventListener('click', function(e) {
                e.preventDefault();
                
                if (revealed) return;
                revealed = true;
                
                // Decode multi-layer obfuscation
                const encodedUser = emailLink.getAttribute('data-u');
                const encodedDomain = emailLink.getAttribute('data-d');
                
                // Step 1: Base64 decode
                const reversedUser = atob(encodedUser);
                const reversedDomain = atob(encodedDomain);
                
                // Step 2: Reverse strings
                const user = reversedUser.split('').reverse().join('');
                const domain = reversedDomain.split('').reverse().join('');
                
                // Step 3: Reconstruct email
                const email = user + domain;
                
                // Update UI with animation
                emailText.style.opacity = '0';
                setTimeout(() => {
                  emailLink.href = 'mailto:' + email;
                  emailText.textContent = email;
                  emailText.style.userSelect = 'text';
                  emailText.style.opacity = '1';
                  emailText.style.transition = 'opacity 0.3s ease';
                }, 150);
              });
              
              // Add hover effect
              emailLink.addEventListener('mouseenter', function() {
                if (!revealed) {
                  emailText.style.textDecoration = 'underline';
                }
              });
              
              emailLink.addEventListener('mouseleave', function() {
                if (!revealed) {
                  emailText.style.textDecoration = 'none';
                }
              });
            })();
          </script>

          <div class="contact-item">
            <span class="label">GitHub:</span>
            <a
              href="https://github.com/konstantysz"
              target="_blank"
              rel="noopener">github.com/konstantysz</a
            >
          </div>

          <div class="contact-item">
            <span class="label">LinkedIn:</span>
            <a
              href="https://linkedin.com/in/konstanty-szumigaj"
              target="_blank"
              rel="noopener">linkedin.com/in/konstanty-szumigaj</a
            >
          </div>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">What I Do</h2>

        <div class="services-grid">
          <div class="service-item">
            <h3>[01] Open-Source Development</h3>
            <p>
              I write tools I'd want to use myself — a node editor for CV pipelines,
              an OpenGL framework, automation bots. Everything on GitHub.
            </p>
          </div>

          <div class="service-item">
            <h3>[02] Research & Prototyping</h3>
            <p>
              Reading papers and turning them into runnable code. Currently working with
              NeRF, Gaussian Splatting, and facial geometry.
            </p>
          </div>

          <div class="service-item">
            <h3>[03] Algorithm Development</h3>
            <p>
              Algorithms for 2D/3D/4D data — object detection, optimization, projection math.
              Usually C++ when performance matters.
            </p>
          </div>

          <div class="service-item">
            <h3>[04] System Architecture</h3>
            <p>
              CV/ML pipelines from prototype to production. Distributed systems, CI/CD,
              the boring parts that make everything else work.
            </p>
          </div>

          <div class="service-item">
            <h3>[05] Performance Optimization</h3>
            <p>
              C++ and CUDA when Python is too slow. Multithreading, memory layout,
              profiling until it's fast enough.
            </p>
          </div>

          <div class="service-item">
            <h3>[06] 3D Vision Systems</h3>
            <p>
              LiDAR, Structure from Motion, photogrammetry. A few years of turning
              point clouds into something useful.
            </p>
          </div>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">Before Reaching Out</h2>

        <p class="mb-0">
          Take a look at my <a href="/projects">projects</a> and
          <a href="/experience">experience</a> first — saves us both time.
        </p>
      </section>

      <section class="section">
        <h2 class="section-title">Location & Availability</h2>

        <div class="availability-info">
          <div class="info-block">
            <h3>Location</h3>
            <p class="text-mono">Warsaw, Poland (GMT+1)</p>
          </div>

          <div class="info-block">
            <h3>Remote Work</h3>
            <p class="text-mono">Available worldwide</p>
          </div>

          <div class="info-block">
            <h3>Languages</h3>
            <p class="text-mono">English (fluent) · Polish (native)</p>
          </div>
        </div>
      </section>
    </main>

    <Footer lang="en" />
  </body>
</html>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-top: 24px;
  }

  .service-item {
    border: 1px solid var(--border);
    padding: 16px;
  }

  .service-item h3 {
    margin-bottom: 12px;
    font-family: monospace;
    color: var(--accent);
  }

  .service-item p {
    margin-bottom: 0;
  }

  .availability-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
  }

  .info-block h3 {
    font-size: 14px;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .info-block p {
    margin-bottom: 0;
  }
</style>
